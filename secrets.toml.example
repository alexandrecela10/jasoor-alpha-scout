# ============================================================
# Jasoor Alpha Scout — Streamlit Cloud Secrets
# ============================================================
# Copy this content to Streamlit Cloud:
# App Settings > Secrets > Paste this content
# ============================================================

# Gemini API key — get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY = "your-gemini-api-key-here"

# Tavily API key — get yours at https://tavily.com
TAVILY_API_KEY = "your-tavily-api-key-here"

# (Optional) Langfuse keys — get yours at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY = "your-langfuse-public-key-here"
LANGFUSE_SECRET_KEY = "your-langfuse-secret-key-here"
LANGFUSE_HOST = "https://cloud.langfuse.com"
