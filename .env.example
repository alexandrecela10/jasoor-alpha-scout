# ============================================================
# Jasoor Alpha Scout — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real keys.
#   cp .env.example .env
# ============================================================

# Gemini API key — get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Tavily API key — get yours at https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# Langfuse keys — get yours at https://cloud.langfuse.com (Settings > API Keys)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# (Optional) Email settings for the "Send Report" feature
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# (Optional) App URL for shareable links in emails
# For local: http://localhost:8501
# For deployed: https://your-app.streamlit.app
APP_URL=http://localhost:8501
